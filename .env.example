VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_URL=http://localhost:8080/ws
VITE_APP_GOOGLE_CLIENT_ID=

# SEO — set the production domain (no trailing slash). At build the SEO plugin will:
#   - inject absolute canonical / og:url / og:image into index.html
#   - generate dist/sitemap.xml and append "Sitemap: <site>/sitemap.xml" to robots.txt
VITE_SITE_URL=http://localhost:5173
VITE_OG_IMAGE_PATH=/og-image.png

# Google Analytics 4 + Ads conversion (prod) — xem docs/GOOGLE-ADS-GUIDE.md
VITE_GA_MEASUREMENT_ID=
VITE_GOOGLE_ADS_CONVERSION_SEND_TO=
